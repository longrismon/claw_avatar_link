# Hermes Agent
HERMES_API_URL=http://localhost:7000
HERMES_API_KEY=

# TTS provider: elevenlabs | coqui | openai
TTS_PROVIDER=coqui
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
OPENAI_API_KEY=

# STT
WHISPER_MODEL=base          # tiny | base | small | medium | large

# LatentSync
LIPSYNC_DEVICE=cpu          # cpu | cuda
LIPSYNC_MODEL_PATH=/models/lipsync

# Avatar
DEFAULT_AVATAR_URL=         # leave blank to use bundled default

# Security
# Comma-separated allowed CORS origins. Use "*" for development only.
ALLOWED_ORIGINS=http://localhost:5173
# Max text input length (chars) and audio buffer (bytes)
MAX_TEXT_LENGTH=2000
MAX_AUDIO_BYTES=10485760
